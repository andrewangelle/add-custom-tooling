{
  "compilerOptions": {
    "types": ["node", "vitest/globals"],
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "target": "es2024",
    "outDir": "dist",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "~/*": ["./src/*"],
      "~tests/*": ["./tests/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"]
}
