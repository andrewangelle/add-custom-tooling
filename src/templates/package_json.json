{
  "scripts": {
    "lint:fix": "{{ PACKAGE_EXEC }} biome check . --write",
    "lint:check": "{{ PACKAGE_EXEC }} biome check .",
    "format": "{{ PACKAGE_EXEC }} biome format . --write",
    "pre-commit": "lint-staged",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "{{ PACKAGE_RUN }} lint:fix",
      "{{ PACKAGE_RUN }} format"
    ]
  }
}
