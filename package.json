    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@npmcli/package-json": "^7.0.1",
    "arg": "^5.0.2",
    "execa": "^9.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.2",
    "@types/node": "^24.9.2",
    "@types/npmcli__package-json": "^4.0.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "pnpm lint:fix",
      "pnpm format"
    ]
