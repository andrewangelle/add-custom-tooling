{
  "name": "add-custom-tooling",
  "version": "1.0.1",
  "description": "",
  "main": "dist/run.mjs",
  "bin": {
    "add-tooling": "dist/run.mjs"
  },
  "type": "module",
  "packageManager": "pnpm@9.10.0",
  "scripts": {
    "clean": "rm -rf ./dist",
    "build": "pnpm clean && tsdown",
    "test": "pnpm build && vitest run",
    "test:coverage": "pnpm test -- --coverage",
    "lint:fix": "pnpm exec biome check . --write --unsafe",
    "lint:check": "pnpm exec biome check .",
    "format": "pnpm exec biome format . --write",
    "pre-commit": "lint-staged",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@npmcli/package-json": "^7.0.1",
    "arg": "^5.0.2",
    "execa": "^9.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.2",
    "@types/node": "^24.9.2",
    "@types/npmcli__package-json": "^4.0.4",
    "@vitest/coverage-v8": "^4.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "pnpm lint:fix",
      "pnpm format"
    ]
  }
}
